{
  "manifest_version": 3,
  "name": "FacMod - Factorio Mod Downloader",
  "version": "0.0.4",
  "description": "One-click Factorio mod downloads, no account required.",
  "permissions": [
    "storage",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://mods.factorio.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mods.factorio.com/*"
      ],
      "js": [
        "src/polyfill.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": [
      "src/polyfill.js",
      "src/background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "facmod@example.com",
      "strict_min_version": "113.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}